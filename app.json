{
  "expo": {
    "name": "تبارك فارما",
    "slug": "tabarak-pharma",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tabarakpharma",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tabarak.pharma",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tabarak.pharma",
      "versionCode": 13,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#121212"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-navigation-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ff6f00",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      "expo-sharing",
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "command": "setBackgroundColorAsync",
        "backgroundColor": "#ffffff",
        "buttonColor": "dark"
      },
      "eas": {
        "projectId": "b0eb3ca8-5d4f-432a-a754-44fd76cc7185"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/b0eb3ca8-5d4f-432a-a754-44fd76cc7185"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "kerd2s545ys"
  }
}
