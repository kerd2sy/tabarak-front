.DS_Store
*.pem

# local env files
.env
.env.*
.env*.local

# Secrets & credentials — NEVER commit these
# Note: google-services.json is safe to commit (client-side config, no private keys)
# The sensitive file is the Firebase Admin SDK JSON (below)
*firebase-adminsdk*.json
serviceAccountKey.json
*-credentials.json

# Misc
doctor_output.txt
ts_errors.txt
update_log.txt

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
