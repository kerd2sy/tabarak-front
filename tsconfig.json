{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/modules/*": ["./src/modules/*"],
      "@/features/*": ["./src/modules/*"],
      "@/context/*": ["./src/shared/app-context/*"],
      "@/api/*": ["./src/shared/api/*"],
      "@/hooks/*": ["./src/shared/hooks/*"],
      "@/utils/*": ["./src/shared/utils/*"],
      "@/constants/*": ["./src/shared/constants/*"],
      "@/store/*": ["./src/shared/store/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/assets/*": ["./assets/*"],
      "@/*": ["./src/*"]
    },

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}